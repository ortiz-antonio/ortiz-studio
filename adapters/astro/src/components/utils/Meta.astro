---
import type { HeroData } from '@core/content/types'

const { data } = Astro.props as { data: HeroData }
---

<meta name="description" content={data.text} />

<meta property="og:title" content={data.title} />
<meta property="og:type" content="website" />
<meta property="og:description" content={data.text} />
<meta property="og:image" content="https://joyeria.ortiz.studio/images/preview.jpg" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={data.title} />
<meta property="og:url" content="https://joyeria.ortiz.studio/" />
<meta name="twitter:card" content="summary_large_image" />
